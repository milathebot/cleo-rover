[Unit]
Description=Cleo Rover PC-side autonomy brain
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/wiffl/projects/cleo-rover
ExecStart=/home/wiffl/projects/cleo-rover/.venv/bin/cleo-rover-brain --base http://127.0.0.1:8099 --interval 5
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
